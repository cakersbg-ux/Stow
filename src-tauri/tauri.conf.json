{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Stow",
  "version": "0.1.0",
  "identifier": "com.stow.app",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1320,
        "height": 840,
        "minWidth": 1080,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "decorations": true,
        "backgroundColor": "#f4f4f4"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../backend/**/*"]
  }
}
