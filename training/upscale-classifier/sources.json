{
  "version": 1,
  "classes": [
    {
      "id": "portrait",
      "targetCount": 12000,
      "description": "Real photos dominated by one or more people, especially face-heavy or upper-body framing.",
      "preferredUpscalers": ["realEsrgan:realesrnet-x4plus", "realEsrgan:realesrgan-x4plus"]
    },
    {
      "id": "landscape",
      "targetCount": 12000,
      "description": "Real outdoor scenes, architecture, nature, streets, travel shots, and wide scenery.",
      "preferredUpscalers": ["realEsrgan:realesrgan-x4plus"]
    },
    {
      "id": "photo",
      "targetCount": 12000,
      "description": "General real-world photography that is neither strongly portrait nor strongly landscape.",
      "preferredUpscalers": ["realEsrgan:realesrgan-x4plus"]
    },
    {
      "id": "illustration",
      "targetCount": 10000,
      "description": "Non-anime drawings, paintings, comics, posters, digital art, and graphic illustration.",
      "preferredUpscalers": ["waifu2x", "realCugan", "realEsrgan:realesrgan-x4plus-anime"]
    },
    {
      "id": "anime",
      "targetCount": 10000,
      "description": "Anime and anime-adjacent still images with cel shading or line-art-heavy stylization.",
      "preferredUpscalers": ["realCugan", "waifu2x", "realEsrgan:realesrgan-x4plus-anime"]
    },
    {
      "id": "ui_screenshot",
      "targetCount": 6000,
      "description": "Screenshots, UI captures, meme composites, and text-heavy graphics.",
      "preferredUpscalers": ["waifu2x", "realEsrgan:realesrgan-x4plus"]
    }
  ],
  "sources": [
    {
      "id": "open_images_v7",
      "kind": "primary",
      "license": "CC BY",
      "status": "approved",
      "url": "https://storage.googleapis.com/openimages/web/download_v7.html",
      "useForClasses": ["portrait", "landscape", "photo"],
      "notes": "Best starting point for real photos with large-scale labels and broad category coverage."
    },
    {
      "id": "places365",
      "kind": "primary",
      "license": "Dataset-specific academic terms",
      "status": "review_required",
      "url": "https://places2.csail.mit.edu/",
      "useForClasses": ["landscape", "photo"],
      "notes": "High-value scene dataset for indoor/outdoor routing, but review terms before shipping a trained commercial classifier from it."
    },
    {
      "id": "wikimedia_commons",
      "kind": "primary",
      "license": "Per-file; only ingest CC0, CC BY, CC BY-SA",
      "status": "approved_with_filtering",
      "url": "https://commons.wikimedia.org/wiki/Commons:Reusing_content_outside_Wikimedia/en",
      "useForClasses": ["portrait", "landscape", "photo", "illustration", "ui_screenshot"],
      "notes": "Use only files with clear reuse licenses and keep attribution metadata."
    },
    {
      "id": "met_open_access",
      "kind": "primary",
      "license": "CC0",
      "status": "approved",
      "url": "https://www.metmuseum.org/about-the-met/policies-and-documents/open-access",
      "useForClasses": ["illustration"],
      "notes": "Strong source for public-domain artwork and digitized collections."
    },
    {
      "id": "nga_open_access",
      "kind": "primary",
      "license": "Open Access / public-domain works",
      "status": "approved",
      "url": "https://www.nga.gov/open-access-images.html",
      "useForClasses": ["illustration"],
      "notes": "Good museum-quality artwork source with reliable metadata."
    },
    {
      "id": "smithsonian_open_access",
      "kind": "primary",
      "license": "CC0",
      "status": "approved",
      "url": "https://www.si.edu/openaccess",
      "useForClasses": ["illustration", "photo"],
      "notes": "Useful for open public-domain imagery and mixed media."
    },
    {
      "id": "artic_open_access",
      "kind": "primary",
      "license": "Open access",
      "status": "approved",
      "url": "https://www.artic.edu/open-access/open-access-images",
      "useForClasses": ["illustration"],
      "notes": "Another clean museum source for paintings, prints, posters, and drawings."
    },
    {
      "id": "danbooru",
      "kind": "secondary",
      "license": "Mixed / site-specific / legal review required",
      "status": "high_risk",
      "url": "https://danbooru.donmai.us/",
      "useForClasses": ["anime"],
      "notes": "Best practical anime-tag source for internal experiments, but not a clean commercial-source default."
    }
  ]
}
